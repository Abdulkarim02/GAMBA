{
    "name": "GAMBA",
    "description": "Generalised AI Browser Assistant",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "tabs",
        "activeTab",
        "storage"
    ],
    "content_scripts": [
        {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
        }
    ],
    "host_permissions": ["https://gamba.almanea.work/*"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": "GAMBA_icon.png"
    }
}