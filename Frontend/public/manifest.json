{
    "name": "GAMBA",
    "description": "Generalised AI Browser Assistant",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "tabs",
        "activeTab",
        "storage"
    ],
    "content_scripts": [
        {
        "matches": ["<all_urls>"],
        "js": ["turndown.js", "content.js"],
        "all_frames": false,
        "run_at": "document_idle"
        }
    ],
    "host_permissions": ["<all_urls>", "https://integrate.api.nvidia.com/*", "https://api.openai.com/*", "http://localhost:8000/*", "https://serpapi.com/*", "https://api.themoviedb.org/*"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "index.html",
        "default_icon": "GAMBA_icon.png"
    }
}